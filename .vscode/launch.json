{
  // 使用 IntelliSense 了解相关属性。
  // 悬停以查看现有属性的描述。
  // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "PyCosim: simulate",
      "type": "debugpy",
      "request": "launch",
      "module": "pycosim",
      "args": [
        "simulate",
        "${workspaceFolder}/examples/bat/BAT_fmu.json",
        "-vv"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false
    },
    {
      "name": "PyCosim: simulate (parallel)",
      "type": "debugpy",
      "request": "launch",
      "module": "pycosim",
      "args": [
        "simulate",
        "${workspaceFolder}/examples/bat/BAT_fmu.json",
        "--parallel",
        "-vv"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false
    },
    {
      "name": "PyCosim: simulate (自选配置)",
      "type": "debugpy",
      "request": "launch",
      "module": "pycosim",
      "args": ["simulate", "${input:configFile}", "-vv"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false
    }
  ],
  "inputs": [
    {
      "id": "configFile",
      "type": "promptString",
      "description": "JSON 配置文件路径",
      "default": "${workspaceFolder}/examples/bat/BAT_fmu.json"
    }
  ]
}
